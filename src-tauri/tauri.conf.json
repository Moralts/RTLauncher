{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rtlauncher",
  "version": "0.1.0",
  "identifier": "com.rtlaucher.dev",
  "build": {
    "beforeDevCommand": "cd RTL-WebUI && pnpm dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "cd RTL-WebUI && pnpm build",
    "frontendDist": "../RTL-WebUI/out"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "RTLauncher",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
